@startuml classes
title VetCare+ - Diagrama de Classes (dominio)

skinparam classAttributeIconSize 0
hide circle

abstract class Usuario {
  - id: Long
  - nome: String
  - email: String
  - senhaHash: String
  - telefone: String
  + autenticar(senha): boolean
}

class Tutor {
  - cpf: String
  - endereco: String
  + cadastrarPet(pet): void
}

class Recepcionista {
  - matricula: String
}

class Veterinario {
  - crmv: String
  - especialidade: String
  + verificarDisponibilidade(data): boolean
}

class Administrador {
  - nivelAcesso: String
}

class Pet {
  - id: Long
  - nome: String
  - especie: String
  - raca: String
  - dataNascimento: Date
  - peso: double
  - sexo: String
}

class Consulta {
  - id: Long
  - dataHora: DateTime
  - status: StatusConsulta
  - motivo: String
  + agendar(): void
  + cancelar(motivo): void
  + concluir(): void
}

enum StatusConsulta {
  AGENDADA
  CONFIRMADA
  REALIZADA
  CANCELADA
}

class Prontuario {
  - id: Long
  - anamnese: String
  - diagnostico: String
  - observacoes: String
  - criadoEm: DateTime
}

class Vacina {
  - id: Long
  - nome: String
  - lote: String
  - aplicadaEm: Date
  - proximaDose: Date
}

class Prescricao {
  - id: Long
  - posologia: String
  - duracaoDias: int
}

class Medicamento {
  - id: Long
  - nome: String
  - principioAtivo: String
}

class Pagamento {
  - id: Long
  - valor: BigDecimal
  - metodo: MetodoPagamento
  - pago: boolean
  - pagoEm: DateTime
}

enum MetodoPagamento {
  PIX
  CARTAO_CREDITO
  CARTAO_DEBITO
  DINHEIRO
}

class Notificacao {
  - id: Long
  - canal: String
  - mensagem: String
  - enviadaEm: DateTime
}

Usuario <|-- Tutor
Usuario <|-- Recepcionista
Usuario <|-- Veterinario
Usuario <|-- Administrador

Tutor "1" --> "0..*" Pet : possui
Pet "1" --> "0..*" Consulta : recebe
Veterinario "1" --> "0..*" Consulta : atende
Recepcionista "1" --> "0..*" Consulta : registra

Consulta "1" --> "0..1" Prontuario : gera
Consulta "1" --> "0..1" Pagamento : tem

Prontuario "1" --> "0..*" Vacina
Prontuario "1" --> "0..*" Prescricao
Prescricao "*" --> "1..*" Medicamento

Consulta -- StatusConsulta
Pagamento -- MetodoPagamento

Tutor "1" --> "0..*" Notificacao : recebe

@enduml
