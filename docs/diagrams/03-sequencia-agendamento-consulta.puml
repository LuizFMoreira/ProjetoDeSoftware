@startuml sequencia-agendar-consulta
title VetCare+ - Sequencia: Tutor agenda consulta

actor Tutor
participant "Front (React)" as UI
participant "AuthFilter" as Auth
participant "ConsultaController" as Ctrl
participant "ConsultaService" as Svc
participant "VeterinarioRepository" as VetRepo
participant "ConsultaRepository" as ConsRepo
participant "NotificacaoService" as Notif
participant "EmailGateway" as Email

Tutor -> UI : escolhe vet, data e horario
UI -> Auth : POST /api/consultas (JWT)
Auth -> Auth : valida token
Auth -> Ctrl : repassa requisicao
Ctrl -> Svc : agendar(dto)

Svc -> VetRepo : buscarPorId(vetId)
VetRepo --> Svc : Veterinario

Svc -> ConsRepo : existeConflito(vetId, dataHora)
ConsRepo --> Svc : false

alt horario livre
  Svc -> ConsRepo : salvar(consulta)
  ConsRepo --> Svc : Consulta(id)
  Svc -> Notif : agendarLembrete(consulta)
  Notif -> Email : enviar(email, msg)
  Email --> Notif : ok
  Svc --> Ctrl : ConsultaDTO
  Ctrl --> UI : 201 Created
  UI --> Tutor : confirmacao na tela
else conflito de horario
  Svc --> Ctrl : ConflitoException
  Ctrl --> UI : 409 Conflict
  UI --> Tutor : "horario indisponivel"
end

@enduml
